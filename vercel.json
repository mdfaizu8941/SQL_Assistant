{
  "version": 2,
  "builds": [
    {
      "src": "sql-assistant/backend/api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "sql-assistant/frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "sql-assistant/backend/api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "sql-assistant/frontend/$1"
    }
  ]
}